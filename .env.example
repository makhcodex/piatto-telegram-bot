# Telegram Bot token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram user ID (get it from @userinfobot)
ADMIN_ID=123456789

# PostgreSQL connection string (asyncpg driver)
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/telegram_bot

# Supabase project URL (found in Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase service role key (found in Settings → API → service_role)
# Keep this secret — it bypasses row-level security
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Public URL of the restaurant logo in Supabase Storage
# Format: https://<project>.supabase.co/storage/v1/object/public/<bucket>/<filename>
# Leave empty to skip the logo and send text-only welcome message
LOGO_URL=https://your-project-id.supabase.co/storage/v1/object/public/assets/piatto-logo.png

# Google Sheets integration (optional — for order sync)
# Path to your Google service account JSON key file
GOOGLE_CREDENTIALS_FILE=service_account.json
# The ID from your Google Sheet URL: /spreadsheets/d/<ID>/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here
